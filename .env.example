# LNET (LACChain) testnet — permissioned EVM, gasPrice = 0
LNET_TESTNET_RPC_URL=http://34.69.184.205:4545
LNET_TESTNET_CHAIN_ID=648540

# Deployer key — must be an LNET writer account authorized to send transactions.
# 0x-prefixed hex private key. Never commit the real value.
PRIVATE_KEY=

# ERC-4337 v0.7 EntryPoint on LNET.
# On public EVM chains the canonical address is 0x0000000071727De22E5E9d8BAf0edAc6f37da032.
# On LNET, set this to the instance deployed via script/DeployEntryPoint.s.sol.
ENTRYPOINT_ADDRESS=

# Off-chain paymaster sponsorship signer (address). Its private key lives in the paymaster service,
# NOT here.
PAYMASTER_SIGNER=

# Optional: wei to deposit into the paymaster's EntryPoint balance on deploy (0 is fine on LNET).
PAYMASTER_DEPOSIT=0
